    "function": "solve_quadratic",
    "content": {
        "3": "def solve_quadratic(a, b, c):",
        "4": "    \"\"\"Решает квадратное уравнение ax² + bx + c = 0 и возвращает результат.\"\"\"",
        "5": "    discriminant = b**2 - 4*a*c",
        "6": "",
        "7": "    if discriminant > 0:",
        "8": "        x1 = (-b + math.sqrt(discriminant)) / (2*a)",
        "9": "        x2 = (-b - math.sqrt(discriminant)) / (2*a)",
        "10": "        return f\"Два корня: x₁ = {x1}, x₂ = {x2}\", discriminant",
        "11": "    elif discriminant == 0:",
        "12": "        x = -b / (2*a)",
        "13": "        return f\"Один корень: x = {x}\", discriminant",
        "14": "    else:",
        "15": "        return \"Нет действительных корней\", discriminant"
    }
}