{
  "type": "file_content",
  "path": "tests\\test_apply_diff_fix.py",
  "content": {
    "1": "# tests/test_apply_diff_fix.py",
    "2": "import json",
    "3": "import os",
    "4": "import sys",
    "5": "import re",
    "6": "import logging",
    "7": "from typing import Dict, Any, List",
    "8": "from unittest.mock import MagicMock",
    "9": "",
    "10": "# Configure logging to show DEBUG messages",
    "11": "logging.basicConfig(level=logging.DEBUG, format='%(levelname)s - %(message)s')",
    "12": "",
    "13": "# Добавляем родительскую директорию в путь для импорта",
    "14": "sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))",
    "15": "",
    "16": "# Теперь импортируем AnswerProcessor",
    "17": "from answers import AnswerProcessor",
    "18": "",
    "19": "# Константы для цветов (упрощенно для pytest)",
    "20": "GREEN = \"\\033[92m\"",
    "21": "RED = \"\\033[91m\"",
    "22": "YELLOW = \"\\033[93m\"",
    "23": "BLUE = \"\\033[94m\"",
    "24": "RESET = \"\\033[0m\"",
    "25": "BOLD = \"\\033[1m\"",
    "26": "",
    "27": "",
    "28": "class TestApplyDiffFix:",
    "29": "    \"\"\"Тест для проверки исправления apply_diff\"\"\"",
    "30": "",
    "31": "    @classmethod",
    "32": "    def setup_class(cls):",
    "33": "        \"\"\"Настройка для всего класса тестов\"\"\"",
    "34": "        cls.processor = AnswerProcessor()",
    "35": "        cls.cases_dir = os.path.join(",
    "36": "            os.path.dirname(__file__), 'assets', 'apply_diff_fix'",
    "37": "        )",
    "38": "",
    "39": "    def load_test_cases(self) -> List[Dict]:",
    "40": "        \"\"\"Загружает тестовые случаи из директорий case_NNN\"\"\"",
    "41": "        if not os.path.isdir(self.cases_dir):",
    "42": "            import pytest",
    "43": "            pytest.skip(f\"Директория с тестами не найдена: {self.cases_dir}\")",
    "44": "            return []",
    "45": "",
    "46": "        test_cases = []",
    "47": "",
    "48": "        for case_name in sorted(os.listdir(self.cases_dir)):",
    "49": "            case_dir = os.path.join(self.cases_dir, case_name)",
    "50": "            if not os.path.isdir(case_dir):",
    "51": "                continue",
    "52": "",
    "53": "            meta_file = os.path.join(case_dir, 'meta.json')",
    "54": "            request_file = os.path.join(case_dir, 'request.json')",
    "55": "            expected_file = os.path.join(case_dir, 'expected.json')",
    "56": "            data_file = os.path.join(case_dir, 'data.json')",
    "57": "",
    "58": "            if not all(os.path.exists(f) for f in [meta_file, request_file, expected_file, data_file]):",
    "59": "                continue",
    "60": "",
    "61": "            with open(meta_file, 'r', encoding='utf-8') as f:",
    "62": "                meta = json.load(f)",
    "63": "",
    "64": "            with open(request_file, 'r', encoding='utf-8') as f:",
    "65": "                request_data = json.load(f)",
    "66": "",
    "67": "            with open(expected_file, 'r', encoding='utf-8') as f:",
    "68": "                expected = json.load(f)",
    "69": "",
    "70": "            with open(data_file, 'r', encoding='utf-8') as f:",
    "71": "                data = json.load(f)",
    "72": "                ",
    "73": "                # Преобразуем строковые ключи в int для content",
    "74": "                if data.get(\"type\") == \"file_content\" and \"content\" in data:",
    "75": "                    content_dict = data[\"content\"]",
    "76": "                    if isinstance(content_dict, dict):",
    "77": "                        # Преобразуем ключи из строк в int",
    "78": "                        data[\"content\"] = {int(k): v for k, v in content_dict.items()}",
    "79": "",
    "80": "            test_cases.append({",
    "81": "                \"name\": case_name,",
    "82": "                \"body\": request_data.get(\"body\", {}),",
    "83": "                \"meta\": meta,",
    "84": "                \"expected\": expected,",
    "85": "                \"data\": data",
    "86": "            })",
    "87": "",
    "88": "        return test_cases",
    "89": "",
    "90": "    def normalize_diff(self, diff: str) -> str:",
    "91": "        \"\"\"Нормализует diff для сравнения (убирает лишние пробелы в конце строк)\"\"\"",
    "92": "        lines = diff.split('\\n')",
    "93": "        normalized = []",
    "94": "        for line in lines:",
    "95": "            normalized.append(line.rstrip())",
    "96": "        return '\\n'.join(normalized)",
    "97": "",
    "98": "    def validate_roo_format(self, diff: str) -> Dict[str, Any]:",
    "99": "        \"\"\"Проверяет, соответствует ли diff формату RooCode.\"\"\"",
    "100": "        result = {",
    "101": "            \"valid\": False,",
    "102": "            \"errors\": [],",
    "103": "            \"warnings\": [],",
    "104": "            \"has_start_line\": False,",
    "105": "            \"has_search_marker\": False,",
    "106": "            \"has_replace_marker\": False,",
    "107": "            \"has_separator\": False",
    "108": "        }",
    "109": "",
    "110": "        # Проверка наличия обязательных маркеров",
    "111": "        if \"<<<<<<< SEARCH\" not in diff:",
    "112": "            result[\"errors\"].append(\"Missing <<<<<<< SEARCH marker\")",
    "113": "        else:",
    "114": "            result[\"has_search_marker\"] = True",
    "115": "",
    "116": "        if \">>>>>> REPLACE\" not in diff:",
    "117": "            result[\"errors\"].append(\"Missing >>>>>>> REPLACE marker\")",
    "118": "        else:",
    "119": "            result[\"has_replace_marker\"] = True",
    "120": "",
    "121": "        if \"=======\" not in diff:",
    "122": "            result[\"errors\"].append(\"Missing ======= separator\")",
    "123": "        else:",
    "124": "            result[\"has_separator\"] = True",
    "125": "",
    "126": "        # Проверка наличия start_line",
    "127": "        if \":start_line:\" not in diff:",
    "128": "            result[\"errors\"].append(\"Missing :start_line: directive\")",
    "129": "        else:",
    "130": "            result[\"has_start_line\"] = True",
    "131": "            start_match = re.search(r':start_line:\\s*(\\d+)', diff)",
    "132": "            if start_match:",
    "133": "                line_num = int(start_match.group(1))",
    "134": "                if line_num <= 0:",
    "135": "                    result[\"errors\"].append(f\"Invalid start_line: {line_num} (must be positive)\")",
    "136": "            else:",
    "137": "                result[\"errors\"].append(\"Invalid :start_line: format\")",
    "138": "",
    "139": "        # Проверка наличия разделителя -------",
    "140": "        if \"-------\" not in diff:",
    "141": "            result[\"warnings\"].append(\"Missing ------- separator (optional but recommended)\")",
    "142": "",
    "143": "        # Проверка порядка секций",
    "144": "        if result[\"has_search_marker\"] and result[\"has_separator\"] and result[\"has_replace_marker\"]:",
    "145": "            search_pos = diff.find(\"<<<<<<< SEARCH\")",
    "146": "            sep_pos = diff.find(\"=======\")",
    "147": "            replace_pos = diff.find(\">>>>>> REPLACE\")",
    "148": "",
    "149": "            if not (search_pos < sep_pos < replace_pos):",
    "150": "                result[\"errors\"].append(\"Incorrect section order\")",
    "151": "",
    "152": "        result[\"valid\"] = len(result[\"errors\"]) == 0",
    "153": "        return result",
    "154": "",
    "155": "    def test_all_cases(self):",
    "156": "        \"\"\"Запускает все тестовые случаи\"\"\"",
    "157": "        test_cases = self.load_test_cases()",
    "158": "        if not test_cases:",
    "159": "            return",
    "160": "",
    "161": "        print(f\"\\n{BOLD}{'='*80}{RESET}\")",
    "162": "        print(f\"{BOLD}ТЕСТИРОВАНИЕ ИСПРАВЛЕНИЯ APPLY_DIFF{RESET}\")",
    "163": "        print(f\"{BOLD}{'='*80}{RESET}\")",
    "164": "        print(f\"\\n📋 Загружено тестов: {len(test_cases)}\")",
    "165": "",
    "166": "        passed = 0",
    "167": "        failed = 0",
    "168": "",
    "169": "        for i, test_case in enumerate(test_cases, 1):",
    "170": "            print(f\"\\n{BOLD}{'='*60}{RESET}\")",
    "171": "            print(f\"{BOLD}ТЕСТ #{i}: {test_case.get('name', 'Без имени')}{RESET}\")",
    "172": "            print(f\"{BOLD}{'='*60}{RESET}\")",
    "173": "",
    "174": "            # === ТЕСТ С DATA ===",
    "175": "            if test_case.get(\"data\"):",
    "176": "                print(f\"\\n{BLUE}  --- Тест с data (поиск актуального start_line) ---{RESET}\")",
    "177": "                try:",
    "178": "                    args = {",
    "179": "                        \"path\": test_case[\"meta\"].get(\"path\", \"test.py\"),",
    "180": "                        \"diff\": test_case[\"body\"].get(\"diff\", \"\")",
    "181": "                    }",
    "182": "",
    "183": "                    # Используем _fix_apply_diff_tool",
    "184": "                    self.processor._fix_apply_diff_tool(args, test_case[\"data\"], debug=False)",
    "185": "",
    "186": "                    actual_diff = args[\"diff\"]",
    "187": "                    print(\"========actual_diff===========\")",
    "188": "                    print(actual_diff)",
    "189": "                    print(\"==============================\")",
    "190": "                    expected_diff = test_case[\"expected\"].get(\"diff\", \"\")",
    "191": "",
    "192": "                    normalized_actual = self.normalize_diff(actual_diff)",
    "193": "                    normalized_expected = self.normalize_diff(expected_diff)",
    "194": "",
    "195": "                    validation = self.validate_roo_format(actual_diff)",
    "196": "",
    "197": "                    if normalized_actual == normalized_expected and validation[\"valid\"]:",
    "198": "                        print(f\"{GREEN}  ✅ С DATA: ПРОЙДЕН{RESET}\")",
    "199": "                        passed += 1",
    "200": "                    else:",
    "201": "                        print(f\"{RED}  ❌ С DATA: НЕ ПРОЙДЕН{RESET}\")",
    "202": "                        failed += 1",
    "203": "",
    "204": "                        if not validation[\"valid\"]:",
    "205": "                            print(f\"{RED}     Ошибки формата:{RESET}\")",
    "206": "                            for error in validation[\"errors\"]:",
    "207": "                                print(f\"{RED}       • {error}{RESET}\")",
    "208": "",
    "209": "                        if normalized_actual != normalized_expected:",
    "210": "                            print(f\"{YELLOW}     Результат не соответствует ожидаемому{RESET}\")",
    "211": "",
    "212": "                            debug_args = {",
    "213": "                                \"path\": test_case[\"meta\"].get(\"path\", \"test.py\"),",
    "214": "                                \"diff\": test_case[\"body\"].get(\"diff\", \"\")",
    "215": "                            }",
    "216": "                            self.processor._fix_apply_diff_tool(debug_args, test_case[\"data\"], debug=True)",
    "217": "",
    "218": "                            actual_lines = normalized_actual.split('\\n')",
    "219": "                            expected_lines = normalized_expected.split('\\n')",
    "220": "",
    "221": "                            if len(actual_lines) != len(expected_lines):",
    "222": "                                print(f\"{YELLOW}       Разное количество строк: actual={len(actual_lines)}, expected={len(expected_lines)}{RESET}\")",
    "223": "",
    "224": "                            diff_count = 0",
    "225": "                            for line_idx, (a, e) in enumerate(zip(actual_lines, expected_lines)):",
    "226": "                                if a != e and diff_count < 3:",
    "227": "                                    print(f\"{YELLOW}       Строка {line_idx+1} отличается:{RESET}\")",
    "228": "                                    print(f\"{YELLOW}         actual:   '{a}'{RESET}\")",
    "229": "                                    print(f\"{YELLOW}         expected: '{e}'{RESET}\")",
    "230": "                                    diff_count += 1",
    "231": "                                    if diff_count >= 3:",
    "232": "                                        print(f\"{YELLOW}         ... (остальные различия скрыты){RESET}\")",
    "233": "                                        break",
    "234": "                except Exception as e:",
    "235": "                    print(f\"{RED}  ❌ С DATA: ОШИБКА: {str(e)}{RESET}\")",
    "236": "                    failed += 1",
    "237": "            else:",
    "238": "                # Если нет data, пропускаем тест",
    "239": "                print(f\"\\n{YELLOW}  --- Нет data, тест пропущен ---{RESET}\")",
    "240": "                continue",
    "241": "",
    "242": "        # Выводим итоговую статистику",
    "243": "        print(f\"\\n{BOLD}{'='*80}{RESET}\")",
    "244": "        print(f\"{BOLD}ИТОГИ ТЕСТИРОВАНИЯ{RESET}\")",
    "245": "        print(f\"{BOLD}{'='*80}{RESET}\")",
    "246": "        print(f\"Всего тестов: {len(test_cases)}\")",
    "247": "        print(f\"{GREEN}✅ Пройдено: {passed}{RESET}\")",
    "248": "        print(f\"{RED}❌ Не пройдено: {failed}{RESET}\")",
    "249": "",
    "250": "        success_rate = round(passed / max(len(test_cases), 1) * 100, 2)",
    "251": "        if success_rate >= 80:",
    "252": "            color = GREEN",
    "253": "        elif success_rate >= 50:",
    "254": "            color = YELLOW",
    "255": "        else:",
    "256": "            color = RED",
    "257": "        print(f\"{color}📊 Успешность: {success_rate}%{RESET}\")",
    "258": "",
    "259": "        # Проваливаем тест, если есть ошибки",
    "260": "        assert failed == 0, f\"{failed} тестов не пройдено\"",
    "261": "",
    "262": "",
    "263": "# Для запуска скрипта напрямую",
    "264": "if __name__ == \"__main__\":",
    "265": "    import pytest",
    "266": "    pytest.main([__file__, \"-v\", \"--tb=short\"])"
  }
}