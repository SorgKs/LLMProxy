    "content": {
        "200": "    def _load_tools_from_folder(self, folder_path):",
        "201": "        \"\"\"Загружает инструменты из указанной папки\"\"\"",
        "202": "        tools = []",
        "203": "        if not os.path.isdir(folder_path):",
        "204": "            return tools",
        "205": "        for filename in os.listdir(folder_path):",
        "206": "            if filename.endswith('.py'):",
        "207": "                filepath = os.path.join(folder_path, filename)",
        "208": "                with open(filepath, 'r', encoding='utf-8') as f:",
        "209": "                    content = f.read()",
        "210": "                tools.append({'name': filename[:-3], 'content': content})",
        "211": "        return tools",
        "212": "        # Сначала загружаем инструменты из папки tools/",
        "213": "        tools_folder = os.path.join(os.path.dirname(config_path) or \".\", \"..\", \"tools\")",
        "214": "        tools_folder = os.path.normpath(tools_folder)",
        "215": "        tools_from_folder = self._load_tools_from_folder(tools_folder)",
        "216": "",
        "217": "        # Собираем имена инструментов из папки",
        "218": "        folder_tool_names = set()",
        "219": "        for tool in tools_from_folder:",
        "220": "            name = tool.get(\"function\", {}).get(\"name\", \"\")",
        "221": "            if name:",
        "222": "                folder_tool_names.add(name)",
        "223": "",
        "224": "        # Если есть инструменты из папки, обновляем default_config",
        "225": "        if folder_tool_names:",
        "226": "            for name in folder_tool_names:",
        "227": "                if name not in default_config:",
        "228": "                    default_config[name] = True",
        "229": "            self.changes_log.append(f\"📁 Загружено {len(tools_from_folder)} инструмент(ов) из папки tools/\")",
        "230": "",
        "231": "        try:",
        "232": "            if os.path.exists(config_path):",
        "233": "                with open(config_path, 'r', encoding='utf-8') as f:",
        "234": "                    config = yaml.safe_load(f)",
        "235": "",
        "236": "                # Парсим YAML структуру: ожидаем tools как корневой ключ",
        "237": "                tools_config = {}",
        "238": "",
        "239": "                tools = config.get(\"tools\")",
        "240": "                if tools and isinstance(tools, dict):",
        "241": "                    for tool_name, tool_enabled in tools.items():",
        "242": "                        tools_config[tool_name] = tool_enabled",
        "243": "",
        "244": "                self.changes_log.append(f\"📋 Загружена конфигурация инструментов из {config_path}\")",
        "245": "",
        "246": "                return tools_config",
        "247": "",
        "248": "        except Exception as e:",
        "249": "            self.changes_log.append(f\"❌ Ошибка загрузки {config_path}: {str(e)}\")",
        "250": "            return default_config"
    }
}