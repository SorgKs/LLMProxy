   Returns:\n 53 |             True если файл существует, False в противном случае\n 54 |         \"\"\"\n 55 |         if not self.workspace_path:\n 56 |             # Если путь не установлен, пробуем определить из environment_details\n 57 |             return False\n 58 |         \n 59 |         full_path = os.path.join(self.workspace_path, file_path)\n 60 |         return os.path.exists(full_path)\n 61 |     \n 62 |     def _extract_workspace_path(self, request_body: Dict[str, Any]) -> Optional[str]:\n 63 |         \"\"\"\n 64 |         Извлекает путь к рабочей директории из environment_details в user messages.\n 65 |         \"\"\"\n 66 |         if \"messages\" not in request_body or not isinstance(request_body[\"messages\"], list):\n 67 |             return None\n 68 |         \n 69 |         for msg in request_body[\"messages\"]:\n 70 |             if msg.get(\"role\") != \"user\" or \"content\" not in msg:\n 71 |                 continue\n 72 |                 \n 73 |             if isinstance(msg[\"content\"], list):\n 74 |                 for item in msg[\"content\"]:\n 75 |                     if item.get(\"type\") == \"text\":\n 76 |                         text = item.get(\"text\", \"\")\n 77 |                         # Ищем путь в environment_details\n 78 |                         match = re.search(r'Current Workspace Directory \\(([^)]+)\\)', text)\n 79 |                         if match:\n 80 |                             return match.group(1)\n 81 |         return None\n 82 |     \n 83 |     def process(self, request_body: Dict[str, Any]) -> Dict[str, Any]:\n 84 |         \"\"\"\n 85 |         ОСНОВНОЙ МЕТОД: Обрабатывает запрос, модифицируя системный промпт.\n 86 |         \n 87 |         Args:\n 88 |             request_body: Оригинальное тело запроса\n 89 |             \n 90 |         Returns:\n 91 |             Модифицированное тело запроса (или оригинал, если изменений не было)\n 92 |         \"\"\"\n 93 |         now = datetime.now().strftime(\"%H:%M:%S\")\n 94 |         self.reset()\n 95 |         \n 96 |         # ЛОГГИРУЕМ ОРИГИНАЛЬНЫЙ ЗАПРОС\n 97 |         log_request(request_body)\n 98 |         \n 99 |         # Обновляем общую статистику\n100 |         self.stats[\"total_requests\"] += 1\n101 |         model = request_body.get(\"model\", \"unknown\")\n102 |         \n103 |         # Статистика по моделям\n104 |         if model not in self.stats[\"requests_by_model\"]:\n105 |             self.stats[\"requests_by_model\"][model] = {\n106 |                 \"total\": 0,\n107 |                 \"modified\": 0,\n108 |                 \"saved_characters\": 0\n109 |             }\n110 |         self.stats[\"requests_by_model\"][model][\"total\"] += 1\n111 |         \n112 |         # Создаем копию для изменений\n113 |         modified_body = json.loads(json.dumps(request_body))\n114 |         \n115 |         # Получаем оригинальный промпт для статистики\n116 |         original_prompt = self._extract_system_prompt(request_body)\n117 |         \n118 |         # 1. Модифицируем системный промпт\n119 |         system_modified = self._modify_system_prompt(modified_body)\n120 |         \n121 |         # 2. Добавляем структуру проекта в отдельную секцию\n122 |         structure_added = self._add_project_structure(modified_body)\n123 |         \n124 |         # 3. Удаляем environment details из user messages и пустые сообщения\n125 |         user_modified = self._clean_user_messages(modified_body)\n126 |         \n127 |         # 4. Оптимизируем описания tools\n128 |         tools_modified = self._optimize_tools(modified_body)\n129 |         \n130 |         # 5. Получаем путь к рабочей директории\n131 |         workspace_path = self._extract_workspace_path(request_body)\n132 |         if workspace_path:\n133 |             self.workspace_path = workspace_path\n134 |             self.project_files_cache = None  # Сбрасываем кэш при смене директории\n135 |         \n136 |         # 6. Проверяем наличие docs/INDEX.md и удаляем инструкцию если файла нет\n137 |         docs_instruction_removed = False\n138 |         if self.workspace_path and not self._check_file_exists(\"docs/INDEX.md\"):\n139 |             docs_instruction_removed = self._remove_docs_instruction(modified_body)\n140 |             if docs_instruction_removed:\n141 |                 self.changes_log.append(\"🗑️ Удалена инструкция по чтению docs/INDEX.md (файл не найден)\")\n142 |         \n143 |         if system_modified or structure_added or user_modified or tools_modified or docs_instruction_removed:\n144 |             self._was_changed = True\n145 |             self.stats[\"modified_requests\"] += 1\n146 |             self.stats[\"requests_by_model\"][model][\"modified\"] += 1\n147 |             \n148 |             # ЛОГГИРУЕМ ИЗМЕНЕННЫЙ ЗАПРОС\n149 |             log_modified_request(modified_body, request_body, self.changes_log)\n150 |             \n151 |             # Получаем модифицированный промпт для статистики\n152 |             modified_prompt = self._extract_system_prompt(modified_body)\n153 |             \n154 |             # Собираем статистику по изменениям\n155 |             if original_prompt and modified_prompt:\n156 |                 self._update_statistics(original_prompt, modified_prompt, model, now)\n157 |                 \n158 |                 changes_desc = []\n159 |                 if system_modified:\n160 |                     changes_desc.append(\"системный промпт\")\n161 |                 if structure_added:\n162 |                     changes_desc.append(\"добавлена структура проекта\")\n163 |                 if user_modified:\n164 |                     changes_desc.append(\"user messages\")\n165 |                 if tools_modified:\n166 |                     changes_desc.append(\"tools\")\n167 |                 if docs_instruction_removed:\n168 |                     changes_desc.append(\"удалена инструкция docs/INDEX.md\")\n169 |                 \n170 |                 print(f\"[{now}] 🔧 Запрос оптимизирован: {', '.join(changes_desc)}\")\n171 |                 print(f\"      - Экономия: {self._calculate_stats(original_prompt, modified_prompt)['saved_characters']} символов ({self._calculate_stats(original_prompt, modified_prompt)['saved_percent']}%)\")\n172 |                 for change in self.changes_log:\n173 |                     print(f\"      - {change}\")\n174 |         \n175 |         return modified_body\n176 |     \n177 |     def _extract_system_prompt(self, request_body: Dict[str, Any]) -> Optional[str]:\n178 |         \"\"\"Извлекает системный промпт из тела запроса\"\"\"\n179 |         if \"messages\" in request_body and isinstance(request_body[\"messages\"], list):\n180 |             for msg in request_body[\"messages\"]:\n181 |                 if msg.get(\"role\") == \"system\" and \"content\" in msg:\n182 |                     return msg[\"content\"]\n183 |         return None\n184 |     \n185 |     def _calculate_stats(self, original: str, modified: str) -> Dict[str, Any]:\n186 |         \"\"\"Рассчитывает статистику по изменениям\"\"\"\n187 |         original_length = len(original)\n188 |         modified_length = len(modified)\n189 |         saved = original_length - modified_length\n190 |         saved_percent = round((saved / original_length * 100), 2) if original_length > 0 else 0\n191 |         \n192 |         # Примерная оценка токенов (4 символа = 1 токен)\n193 |         estimated_tokens_saved = saved // 4\n194 |         \n195 |         return {\n196 |             \"original_length\": original_length,\n197 |             \"modified_length\": modified_length,\n198 |             \"saved_characters\": saved,\n199 |             \"saved_percent\": saved_percent,\n200 |             \"estimated_tokens_saved\": estimated_tokens_saved,\n201 |             \"original_lines\": len(original.split('\\n')),\n202 |             \"modified_lines\": len(modified.split('\\n'))\n203 |         }\n204 |     \n205 |     def _update_statistics(self, original_prompt: str, modified_prompt: str, model: str, timestamp: str) -> None:\n206 |         \"\"\"\n207 |         Обновляет всю статистику на основе изменений в промпте.\n208 |         \n209 |         Args:\n210 |             original_prompt: Оригинальный системный промпт\n211 |             modified_prompt: Модифицированный системный промпт\n212 |             model: Название модели\n213 |             timestamp: Временная метка для записи\n214 |         \"\"\"\n215 |         stats = self._calculate_stats(original_prompt, modified_prompt)\n216 |         \n217 |         # Обновляем общую статистику\n218 |         self.stats[\"total_saved_characters\"] += stats[\"saved_characters\"]\n219 |         self.stats[\"total_original_length\"] += stats[\"original_length\"]\n220 |         self.stats[\"total_modified_length\"] += stats[\"modified_length\"]\n221 |         self.stats[\"requests_by_model\"][model][\"saved_characters\"] += stats[\"saved_characters\"]\n222 |         \n223 |         # Пересчитываем средний процент экономии\n224 |         if self.stats[\"total_original_length\"] > 0:\n225 |             self.stats[\"average_saving_percent\"] = round(\n226 |                 (1 - self.stats[\"total_modified_length\"] / self.stats[\"total_original_length\"]) * 100, \n227 |                 2\n228 |             )\n229 |         \n230 |         # Сохраняем в историю последних 10 модификаций\n231 |         modification_record = {\n232 |             \"timestamp\": timestamp,\n233 |             \"model\": model,\n234 |             \"original_length\": stats[\"original_length\"],\n235 |             \"modified_length\": stats[\"modified_length\"],\n236 |             \"saved_characters\": stats[\"saved_characters\"],\n237 |             \"saved_percent\": stats[\"saved_percent\"],\n238 |             \"estimated_tokens_saved\": stats[\"estimated_tokens_saved\"],\n239 |             \"original_lines\": stats[\"original_lines\"],\n240 |             \"modified_lines\": stats[\"modified_lines\"],\n241 |             \"changes\": self.changes_log.copy()\n242 |         }\n243 |         \n244 |         self.stats[\"last_10_modifications\"].append(modification_record)\n245 |         if len(self.stats[\"last_10_modifications\"]) > 10:\n246 |             self.stats[\"last_10_modifications\"].pop(0)\n247 |         \n248 |         # Логируем статистику\n249 |         log_stats(modification_record)\n250 |     \n251 |     def _modify_system_prompt(self, request_body: Dict[str, Any]) -> bool:\n252 |         \"\"\"Находит системный промпт в сообщениях и оптимизирует его.\"\"\"\n253 |         if \"messages\" not in request_body or not isinstance(request_body[\"messages\"], list):\n254 |             return False\n255 |         \n256 |         found = False\n257 |         \n258 |         for msg in request_body[\"messages\"]:\n259 |             if msg.get(\"role\") == \"system\" and \"content\" in msg:\n260 |                 original_content = msg[\"content\"]\n261 |                 modified_content = self._modify_prompt_content(original_content)\n262 |                 \n263 |                 if modified_content != original_content:\n264 |                     msg[\"content\"] = modified_content\n265 |                     found = True\n266 |                     self.changes_log.append(\"Оптимизирована секция SYSTEM INFORMATION\")\n267 |         \n268 |         return found\n269 |     \n270 |     def _modify_prompt_content(self, prompt: str) -> str:\n271 |         \"\"\"Основная логика модификации промпта.\"\"\"\n272 |         # Разделяем на секции по разделителю '===='\n273 |         sections = re.split(r'\\n={4,}\\n', prompt)\n274 |         \n275 |         # Если нет разделителей, возвращаем как есть\n276 |         if len(sections) <= 1:\n277 |             return prompt\n278 |         \n279 |         processed_sections = []\n280 |         system_info_data = None\n281 |         \n282 |         for section in sections:\n283 |             section = section.strip()\n284 |             \n285 |             # Проверяем, является ли секция SYSTEM INFORMATION\n286 |             if section.startswith(\"SYSTEM INFORMATION\"):\n287 |                 # Извлекаем только данные из секции\n288 |                 system_info_data = self._extract_system_info_data(section)\n289 |                 self.changes_log.append(\"Извлечены данные из SYSTEM INFORMATION (удалены текстовые описания)\")\n290 |             else:\n291 |                 # Оставляем остальные секции как есть\n292 |                 processed_sections.append(section)\n293 |         \n294 |         # Собираем финальный промпт\n295 |         if system_info_data:\n296 |             # Сначала все обычные секции\n297 |             result = \"\\n====\\n\".join(processed_sections)\n298 |             # Потом добавляем данные SYSTEM INFORMATION без заголовка\n299 |             result += f\"\\n====\\n{system_info_data}\"\n300 |         else:\n301 |             result = \"\\n====\\n\".join(processed_sections)\n302 |         \n303 |         return result\n304 |     \n305 |     def _extract_system_info_data(self, section: str) -> str:\n306 |         \"\"\"Извлекает только данные из секции SYSTEM INFORMATION.\"\"\"\n307 |         lines = section.split('\\n')\n308 |         data_lines = []\n309 |         \n310 |         # Паттерны для строк с данными\n311 |         data_patterns = [\n312 |             r'^Operating System:',\n313 |             r'^Default Shell:',\n314 |             r'^Home Directory:',\n315 |             r'^Current Workspace Directory:',\n316 |             r'^Current Date and Time:',\n317 |             r'^Core Operating System Information:',\n318 |         ]\n319 |         \n320 |         for line in lines:\n321 |             line = line.strip()\n322 |             # Проверяем, соответствует ли строка одному из паттернов данных\n323 |             if any(re.match(pattern, line) for pattern in data_patterns):\n324 |                 data_lines.append(line)\n325 |             # Также сохраняем пустые строки между данными для форматирования\n326 |             elif line == \"\" and data_lines and not data_lines[-1] == \"\":\n327 |                 data_lines.append(\"\")\n328 |         \n329 |         # Убираем лишние пустые строки в начале и конце\n330 |         while data_lines and data_lines[0] == \"\":\n331 |             data_lines.pop(0)\n332 |         while data_lines and data_lines[-1] == \"\":\n333 |             data_lines.pop()\n334 |         \n335 |         return \"\\n\".join(data_lines)\n336 |     \n337 |     def _clean_user_messages(self, request_body: Dict[str, Any]) -> bool:\n338 |         \"\"\"\n339 |         УДАЛЯЕТ environment details из user messages\n340 |         и полностью удаляет пустые user сообщения.\n341 |         \"\"\"\n342 |         modified = False\n343 |         \n344 |         if \"messages\" not in request_body or not isinstance(request_body[\"messages\"], list):\n345 |             return modified\n346 |         \n347 |         # Создаем новый список сообщений без пустых user сообщений\n348 |         cleaned_messages = []\n349 |         \n350 |         for msg in request_body[\"messages\"]:\n351 |             if msg.get(\"role\") != \"user\":\n352 |                 cleaned_messages.append(msg)\n353 |                 continue\n354 |                 \n355 |             if \"content\" not in msg or not isinstance(msg[\"content\"], list):\n356 |                 cleaned_messages.append(msg)\n357 |                 continue\n358 |             \n359 |             # Отфильтровываем environment_details из content\n360 |             original_content = msg[\"content\"]\n361 |             new_content = []\n362 |             \n363 |             for item in original_content:\n364 |                 if item.get(\"type\") == \"text\":\n365 |                     text = item.get(\"text\", \"\")\n366 |                     # Если это environment_details - пропускаем\n367 |                     if text.strip().startswith(\"<environment_details>\"):\n368 |                         modified = True\n369 |                         self.changes_log.append(\"🗑️ Удалены environment details из user message\")\n370 |                     else:\n371 |                         new_content.append(item)\n372 |                 else:\n373 |                     new_content.append(item)\n374 |             \n375 |             # Если после фильтрации content стал пустым - НЕ добавляем сообщение\n376 |             if new_content:\n377 |                 msg[\"content\"] = new_content\n378 |                 cleaned_messages.append(msg)\n379 |                 modified = True\n380 |             else:\n381 |                 # Сообщение полностью пустое - пропускаем его\n382 |                 modified = True\n383 |                 self.changes_log.append(\"🗑️ Удалено пустое user сообщение\")\n384 |         \n385 |         # Обновляем messages в request_body\n386 |         if len(cleaned_messages) != len(request_body[\"messages\"]):\n387 |             request_body[\"messages\"] = cleaned_messages\n388 |             modified = True\n389 |         \n390 |         return modified\n391 |     \n392 |     def _remove_docs_instruction(self, request_body: Dict[str, Any]) -> bool:\n393 |         \"\"\"\n394 |         Удаляет инструкцию по чтению docs/INDEX.md из системного промпта,\n395 |         если файл не существует.\n396 |         \n397 |         Returns:\n398 |             True если инструкция была удалена, False в противном случае\n399 |         \"\"\"\n400 |         if \"messages\" not in request_body or not isinstance(request_body[\"messages\"], list):\n401 |             return False\n402 |         \n403 |         found = False\n404 |         \n405 |         for msg in request_body[\"messages\"]:\n406 |             if msg.get(\"role\") == \"system\" and \"content\" in msg:\n407 |                 original_content = msg[\"content\"]\n408 |                 \n409 |                 # Паттерн для поиска инструкции по docs/INDEX.md\n410 |                 pattern = r'-\\s*\\*\\*Mandatory first step:\\*\\*\\s*Thoroughly consult the project documentation in `docs/` \\(starting with `docs/INDEX.md`\\) to understand existing architecture, decisions, and constraints\\. Use `read_file`\\.\\s*'\n411 |                 \n412 |                 # Проверяем наличие инструкции\n413 |                 if re.search(pattern, original_content, flags=re.MULTILINE | re.DOTALL):\n414 |                     # Удаляем инструкцию\n415 |                     modified_content = re.sub(pattern, '', original_content, flags=re.MULTILINE | re.DOTALL)\n416 |                     \n417 |                     # Очищаем лишние пустые строки\n418 |                     modified_content = re.sub(r'\\n\\s*\\n\\s*\\n', '\\n\\n', modified_content)\n419 |                     \n420 |                     msg[\"content\"] = modified_content\n421 |                     found = True\n422 |         \n423 |         return found\n424 |     \n425 |     def _add_project_structure(self, request_body: Dict[str, Any]) -> bool:\n426 |         \"\"\"\n427 |         Добавляет структуру проекта в отдельную секцию project_code_structure\n428 |         в самое начало user messages.\n429 |         \"\"\"\n430 |         if not self.workspace_path:\n431 |             return False\n432 |         \n433 |         modified = False\n434 |         \n435 |         try:\n436 |             # Сканируем проект\n437 |             scanner = ProjectStructureScanner()\n438 |             structure = scanner.scan(self.workspace_path, lang=\"python\")\n439 |             \n440 |             # Форматируем структуру в отдельную секцию\n441 |             structure_section = f\"\"\"<project_code_structure>\n442 | {structure}\n443 | </project_code_structure>\"\"\"\n444 |             \n445 |             # Ищем первое user сообщение и добавляем структуру в начало\n446 |             if \"messages\" in request_body and isinstance(request_body[\"messages\"], list):\n447 |                 for msg in request_body[\"messages\"]:\n448 |                     if msg.get(\"role\") == \"user\" and \"content\" in msg and isinstance(msg[\"content\"], list):\n449 |                         # Вставляем структуру в начало content\n450 |                         msg[\"content\"].insert(0, {\n451 |                             \"type\": \"text\",\n452 |                             \"text\": structure_section\n453 |                         })\n454 |                         modified = True\n455 |                         self.changes_log.append(\"📁 Добавлена структура проекта в секцию project_code_structure\")\n456 |                         break\n457 |         \n458 |         except Exception as e:\n459 |             print(f\"Ошибка при сканировании проекта: {e}\")\n460 |         \n461 |         return modified\n462 |     \n463 |     def _optimize_tools(self, request_body: Dict[str, Any]) -> bool:\n464 |         \"\"\"\n465 |         Оптимизирует описания инструментов:\n466 |         - Удаляет все описания параметров\n467 |         - Удаляет indentation полностью\n468 |         - Удаляет mode полностью\n469 |         - Оставляет только path в required\n470 |         - Упрощает description функции\n471 |         \"\"\"\n472 |         modified = False\n473 |         \n474 |         if \"tools\" not in request_body or not isinstance(request_body[\"tools\"], list):\n475 |             return modified\n476 |         \n477 |         for tool in request_body[\"tools\"]:\n478 |             if tool.get(\"type\") != \"function\" or \"function\" not in tool:\n479 |                 continue\n480 |             \n481 |             func = tool[\"function\"]\n482 |             \n483 |             # Оптимизируем только read_file\n484 |             if func.get(\"name\") == \"read_file\":\n485 |                 # Упрощаем description функции\n486 |                 if \"description\" in func:\n487 |                     func[\"description\"] = \"returns up to 2000 lines per file\"\n488 |                     modified = True\n489 |                 \n490 |                 # Оптимизируем параметры\n491 |                 if \"parameters\" in func and isinstance(func[\"parameters\"], dict):\n492 |                     params = func[\"parameters\"]\n493 |                     \n494 |                     # Упрощаем path description\n495 |                     if \"properties\" in params and \"path\" in params[\"properties\"]:\n496 |                         if \"description\" in params[\"properties\"][\"path\"]:\n497 |                             params[\"properties\"][\"path\"][\"description\"] = \"relative to the workspace\"\n498 |                             modified = True\n499 |                     \n500 |                     # Удаляем mode полностью\n501 |                     if \"properties\" in params and \"mode\" in params[\"properties\"]:\n502 |                         del params[\"properties\"][\"mode\"]\n503 |                         modified = True\n504 |                         self.changes_log.append(\"🗑️ Удален mode из read_file\")\n505 |                     \n506 |                     # Удаляем indentation полностью\n507 |                     if \"properties\" in params and \"indentation\" in params[\"properties\"]:\n508 |                         del params[\"properties\"][\"indentation\"]\n509 |                         modified = True\n510 |                         self.changes_log.append(\"🗑️ Удален indentation из read_file\")\n511 |                     \n512 |                     # Удаляем все описания у оставшихся параметров\n513 |                     for param_name, param_props in params.get(\"properties\", {}).items():\n514 |                         if \"description\" in param_props:\n515 |                             del param_props[\"description\"]\n516 |                             modified = True\n517 |                     \n518 |                     # Оставляем только path в required\n519 |                     if \"required\" in params:\n520 |                         params[\"required\"] = [\"path\"]\n521 |                         modified = True\n522 |         \n523 |         return modified\n524 |     \n525 |     def get_summary_stats(self) -> Dict[str, Any]:\n526 |         \"\"\"Возвращает сводную статистику по всем обработанным запросам\"\"\"\n527 |         return {\n528 |             \"total_requests\": self.stats[\"total_requests\"],\n529 |             \"modified_requests\": self.stats[\"modified_requests\"],\n530 |             \"modification_rate\": round(self.stats[\"modified_requests\"] / max(self.stats[\"total_requests\"], 1) * 100, 2),\n531 |             \"total_saved_characters\": self.stats[\"total_saved_characters\"],\n532 |             \"average_saving_percent\": self.stats[\"average_saving_percent\"],\n533 |             \"estimated_total_tokens_saved\": self.stats[\"total_saved_characters\"] // 4,\n534 |             \"requests_by_model\": self.stats[\"requests_by_model\"],\n535 |             \"last_modifications\": self.stats[\"last_10_modifications\"]\n536 |         }\n537 |     \n538 |     def print_summary(self):\n539 |         \"\"\"Выводит сводную статистику в консоль\"\"\"\n540 |         print(\"\\n\" + \"=\"*80)\n541 |         print(\"📊 СТАТИСТИКА ОБРАБОТКИ ЗАПРОСОВ\")\n542 |         print(\"=\"*80)\n543 |         print(f\"Всего запросов: {self.stats['total_requests']}\")\n544 |         print(f\"Модифицировано: {self.stats['modified_requests']} ({round(self.stats['modified_requests']/max(self.stats['total_requests'],1)*100,2)}%)\")\n545 |         print(f\"Всего сохранено символов: {self.stats['total_saved_characters']}\")\n546 |         print(f\"Средняя экономия: {self.stats['average_saving_percent']}%\")\n547 |         print(f\"Примерно сохранено токенов: {self.stats['total_saved_characters'] // 4}\")\n548 |         print(\"-\"*80)\n549 |         print(\"По моделям:\")\n550 |         for model, data in self.stats[\"requests_by_model\"].items():\n551 |             print(f\"  {model}:\")\n552 |             print(f\"    запросов: {data['total']}\")\n553 |             print(f\"    модифицировано: {data['modified']} ({round(data['modified']/max(data['total'],1)*100,2)}%)\")\n554 |             print(f\"    сохранено символов: {data['saved_characters']}\")\n555 |         print(\"=\"*80 + \"\\n\")"
          }
        ]
